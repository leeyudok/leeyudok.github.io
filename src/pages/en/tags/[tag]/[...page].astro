---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { t } from "@/i18n/utils";

const lang = "en" as const;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const langPosts = posts.filter(p => (p.data.lang ?? "ko") === "en");
  const tags = getUniqueTags(langPosts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(langPosts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
---

<Layout title={`${t(lang, "tags.tagPrefix")} ${tagName} | ${SITE.title}`} lang={lang}>
  <Header lang={lang} />
  <Main
    pageTitle={[`${t(lang, "tags.tagPrefix")}`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`All the articles with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`${t(lang, "tags.tagPrefix")}${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} lang={lang} />

  <Footer noMarginTop={page.lastPage > 1} lang={lang} />
</Layout>
